# Bu dosya repoya commitlenebilir; gerçek `.env` dosyasını `.gitignore` korur.

# AI sağlayıcı: ollama (ücretsiz, lokal) veya cursor (ücretli, bulut)
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# CURSOR_API_KEY=cursor_...      # AI_PROVIDER=cursor için

# Raspberry Pi deploy hedefi
PI_HOST=192.168.1.60
PI_USER=mennano
PI_PASSWORD=
PI_REPO_DIR=agora-voice-chatbot-web
PI_BRANCH=main
# Not: ayrı `down` yok — eski container build bitene kadar ayakta kalır (sıfır/az downtime).
PI_DEPLOY_CMD=git pull origin main && docker compose up -d --build --remove-orphans
